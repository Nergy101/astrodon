{
  "name": "@nergy101/astrodon",
  "version": "0.2.7",
  "license": "MIT",
  "description": "A tiny Deno static site toolkit. Build markdown with TypeScript-powered templates, and serve the output with a minimal dev server.",
  "exports": "./mod.ts",
  "tasks": {
    "benchmark": "deno run --allow-read --allow-write --allow-run --allow-net performance-test.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-net",
    "publish": "deno publish"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.1.1",
    "@std/path": "jsr:@std/path@^1.1.5"
  },
  "publish": {
    "include": [
      "mod.ts",
      "build.ts",
      "serve.ts",
      "template.ts",
      "README.md",
      "LICENSE"
    ]
  },
  "compatibility": {
    "deno": "^2.5.0",
    "bun": "^1.0.0"
  }
}